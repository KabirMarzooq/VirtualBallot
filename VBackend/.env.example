# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/virtualballot

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_this_with_another_long_random_string
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Payment ───────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your React frontend URL
FRONTEND_URL=http://localhost:5173

# ── Email (OTP) ───────────────────────────────────────────────────────────────
# Use Gmail App Password or any SMTP service
# For testing: use Mailtrap (https://mailtrap.io) — free, catches all emails
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
EMAIL_FROM=noreply@virtualballot.app

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=5

SUPERADMIN_EMAIL=superadmin@virtualballot.app
SUPERADMIN_SECRET=generate_with_node_crypto_randomBytes_48
# HMAC secret for signing/verifying official roster CSV templates (keep private)
VB_TEMPLATE_SECRET=your-secret-key-here
